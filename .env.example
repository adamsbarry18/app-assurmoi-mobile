# Copier vers .env (Expo charge EXPO_PUBLIC_* au démarrage)

# — Expo **Web** (navigateur) + API en Docker / Node sur le **même** poste :
#     EXPO_PUBLIC_API_URL=http://localhost:3000
# — Téléphone (Expo Go) sur le Wi‑Fi, API sur le Mac :
#     EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
# — Sans variable : défauts (émulateur Android → 10.0.2.2, web/iOS sim → localhost)

# EXPO_PUBLIC_API_URL=
